/*
 * Cirque Trackpad - Right (peripheral) side
 * Connected via I2C through OLED header (SDA P0.17, SCL P0.20)
 * Cirque I2C address: 0x2A
 * Using polling mode (no data-ready GPIO needed)
 */

&pro_micro_i2c {
	glidepoint: glidepoint@2a {
		compatible = "cirque,pinnacle";
		reg = <0x2a>;
		status = "okay";
		sensitivity = "4x";
	};
};

&glidepoint_split {
	input = <&glidepoint>;
};
